# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js (no leading slash — ignore .next at repo root and nested)
.next/
out/

# production
/build

# local dev lead captures (when Supabase is not configured)
/tmp/

# local gallery uploads (keep folder via .gitkeep)
/public/uploads/gallery/*
!/public/uploads/gallery/.gitkeep

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# OpenNext
.open-next

# Cloudflare (local secrets / wrangler state)
.dev.vars
.wrangler/

# Supabase (public — safe in client bundles)
# URL: Dashboard → Project Settings → API (hosted: https://xxxx.supabase.co; local CLI: http://127.0.0.1:54321)
# Anon / publishable key: Project Settings → API (legacy JWT starts with eyJ; newer keys start with sb_publishable_)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: admin API + public lead forms fallback when anon key is missing (insert runs on server only).
# Project Settings → API → service_role (legacy JWT or newer secret key)
SUPABASE_SERVICE_ROLE_KEY=

# Storage: bucket name for admin → Gallery image uploads (server uses service role). Must exist in Supabase.
# Leave empty to use the default bucket name "gallery-uploads", OR set your own name and create a bucket with that exact name.
# Dashboard: Storage → New bucket → name = gallery-uploads (or your name) → turn ON "Public bucket" so images load on the site.
SUPABASE_GALLERY_BUCKET=gallery-uploads

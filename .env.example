# Supabase (public — safe in client bundles)
# URL: Dashboard → Project Settings → API (hosted: https://xxxx.supabase.co; local CLI: http://127.0.0.1:54321)
# Anon key: same page — JWT string starting with eyJ...
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only: required for admin API (list/count leads, manage offers). Never expose in the browser.
# Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=
